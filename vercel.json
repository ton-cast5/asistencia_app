{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py",
      "methods": ["GET", "POST", "PATCH", "DELETE", "OPTIONS"]
    },
    { "src": "/register", "dest": "/templates/register.html" },
    { "src": "/dashboard/alumno", "dest": "/templates/dashboard_alumno.html" },
    { "src": "/dashboard/profesor", "dest": "/templates/dashboard_profesor.html" },
    { "src": "/", "dest": "/templates/login.html" }
  ]
}